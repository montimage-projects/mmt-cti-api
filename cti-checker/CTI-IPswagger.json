{"definition": {
  "openapi" : "3.1.0",
  "servers" : [ {
    "description" : "CTI Check API",
    "url" : "http://localhost:4000"
  } ],
  "info" : {
    "description" : "API to check CTI available info.",
    "version" : "1.0.0",
    "title" : "Cyber Threat Intelligence Checker"
  },
  "tags" : [ {
    "name" : "Address Checker",
    "description" : "Operations to check if an IP is in a black-list"
  },
{
    "name": "Address Checker",
    "description": "Operations to check if an IP is in a black-list"
  },
  {
    "name": "STIX Import",
    "description": "Operations to receive STIX bundles from partners"
  },
  {
    "name" : "Chart Generator",
    "description" : "Generates a chart that indicates the occurrence of an IP Address or Credential in our resources - grouped by days/weeks/months"
  },{
    "name": "Analysis",
    "description":"Analyze IP address integrate LLM"
  }
],
  "paths" : {
    "/chart/address/{ADDRESS}":{
      "get": {
        "description": "Chart generator (days X number of resources that listed the dangerous address) - grouped by days/weeks/months",
        "tags" : [ "Chart Generator" ],
        "parameters" : [ {
          "in" : "path",
          "name" : "ADDRESS",
          "description" : "pass the IP address to generate a chart (days X number of resources that listed the IP) [whole period]",
          "required" : true,
          "schema" : {
            "type" : "string"
            }
          },
          {
            "in" : "query",
            "name" : "GROUPBY",
            "description" : "pass the type of groupBy for the chart [day, week, month], if empty chart will group by day",
            "required" : false,
            "schema" : {
              "type" : "string",
              "example":"day"
              
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the Chart Generated in a PNG file",
            "content": {
              "image/png": {}
            }
          }
        }
      }
    },
    "/chartPath/address/{ADDRESS}":{
      "get": {

        "description": "Chart generator (days X number of resources that listed the dangerous address) - grouped by days/weeks/months",
        "tags" : [ "Chart Generator" ],
        "parameters" : [ {
          "in" : "path",
          "name" : "ADDRESS",
          "description" : "pass the IP address to generate a chart (days X number of resources that listed the IP) [whole period]",
          "required" : true,
          "schema" : {
            "type" : "string"
            }
          },
          {
            "in" : "query",
            "name" : "GROUPBY",
            "description" : "pass the type of groupBy for the chart [day, week, month], if empty chart will group by day",
            "required" : false,
            "schema" : {
              "type" : "string",
              "example":"day"
              
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the Chart Generated in a PNG file",
            "content": {
              "image path": {}
            }
          }
        }
      }
    },
    "/chart/credential/{CREDENTIAL}":{
      "get": {
        "description": "Chart generator (days X number of attempts to login using the given credential in our HoneyPot) - grouped by days/weeks/months",
        "tags" : [ "Chart Generator" ],
        "parameters" : [ {
          "in" : "path",
          "name" : "CREDENTIAL",
          "description" : "pass the credential to generate a chart (days X of attempts to login using the given credential in our HoneyPot) [whole period]",
          "required" : true,
          "schema" : {
            "type" : "string"
            }
          },
          {
            "in" : "query",
            "name" : "GROUPBY",
            "description" : "pass the type of groupBy for the chart [day, week, month], if empty chart will group by day",
            "required" : false,
            "schema" : {
              "type" : "string",
              "example":"day"
              
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the Chart Generated in a PNG file",
            "content": {
              "image/png": {}
            }
          }
        }
      }
    },
    "/check/{ADDRESS}" : {
      "get" : {
        "tags" : [ "Address Checker" ],
        "summary" : "Unified endpoint to check IP, subnet, or domain",
        "operationId" : "checkAddress",
        "description" : "Checks if the given address (IPv4, subnet, or domain) exists in the dangerous IP database. Supports DNS resolution for domains and subnet matching for IPs.",
        "parameters" : [ {
          "in" : "path",
          "name" : "ADDRESS",
          "description" : "pass an IP address, subnet (CIDR), or domain name to be checked",
          "required" : true,
          "schema" : {
            "type" : "string",
            "example" : "192.168.1.1"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "search results matching the address",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/AddressItem"
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "invalid address format"
          }
        }
      }
    },
    "/stix" : {
      "post" : {
        "tags" : [ "STIX Import" ],
        "summary" : "Receive STIX bundle from partner",
        "operationId" : "importStixBundle",
        "description" : "Upload a STIX 2.1 bundle to import threat intelligence data. Supports vulnerability, identity, report, threat-actor, malware, and other STIX object types. Requires API key authentication.",
        "security" : [ {
          "ApiKeyAuth" : [ ]
        } ],
        "parameters" : [ {
          "in" : "header",
          "name" : "X-API-Key",
          "description" : "Partner API key required for authentication",
          "required" : true,
          "schema" : {
            "type" : "string",
            "example" : "partner1-secret-key"
          }
        } ],
        "requestBody" : {
          "required" : true,
          "content" : {
            "application/json" : {
              "schema" : {
                "type" : "object",
                "properties" : {
                  "type" : {
                    "type" : "string",
                    "example" : "bundle"
                  },
                  "id" : {
                    "type" : "string",
                    "example" : "bundle--eea2e291-965c-58e7-baf6-273ffef87ffa"
                  },
                  "objects" : {
                    "type" : "array",
                    "items" : {
                      "type" : "object"
                    },
                    "example" : [
                      {
                        "type": "vulnerability",
                        "spec_version": "2.1",
                        "id": "vulnerability--20dc53e3-c68a-5073-ade6-556bb445e9d3",
                        "name": "CVE-2025-14847"
                      }
                    ]
                  }
                },
                "required" : [ "type", "id" ]
              }
            }
          }
        },
        "responses" : {
          "200" : {
            "description" : "STIX bundle imported successfully",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "object",
                  "properties" : {
                    "success" : {
                      "type" : "boolean"
                    },
                    "message" : {
                      "type" : "string"
                    },
                    "bundle_id" : {
                      "type" : "string"
                    },
                    "object_count" : {
                      "type" : "integer"
                    }
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "Invalid STIX bundle format"
          },
          "401" : {
            "description" : "Missing API key. Provide X-API-Key header."
          },
          "403" : {
            "description" : "Invalid API key"
          },
          "500" : {
            "description" : "Failed to process STIX bundle"
          }
        }
      }
    },
    "/ip/{IP}" : {
      "get" : {
        "tags" : [ "Address Checker" ],
        "summary" : "searches database for a matching IP",
        "operationId" : "searchIP",
        "description" : "By passing in the appropriate options (IP in path), you can search for\nthe exact given IP in our database, without taking subnets into account.\n",
        "parameters" : [ {
          "in" : "path",
          "name" : "IP",
          "description" : "pass the IP address to be checked in our database",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "search results matching the same IP",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/AddressItem"
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "bad input parameter"
          }
        }
      }
    },
    "/subnet/{SUBNET}" : {
      "get" : {
        "tags" : [ "Address Checker" ],
        "summary" : "searches database for a matching SUBNET",
        "operationId" : "searchSubnet",
        "description" : "By passing in the appropriate options (SUBNET in path), you can search for\nthe exact given SUBNET in our database.\n",
        "parameters" : [ {
          "in" : "path",
          "name" : "SUBNET",
          "description" : "pass the SUBNET address to be checked in our database",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "search results matching the same SUBNET",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/AddressItem"
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "bad input parameter"
          }
        }
      }
    },
    "/password/{PASSWORD}" : {
      "get" : {
        "tags" : [ "Credential Checker" ],
        "summary" : "searches database for a matching PASSWORD",
        "operationId" : "searchPassword",
        "description" : "By passing in the appropriate options (PASSWORD in path), you can search for\nthe exact given PASSWORD in our database.\n",
        "parameters" : [ {
          "in" : "path",
          "name" : "PASSWORD",
          "description" : "pass the PASSWORD to be checked in our database",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "search results matching the same PASSWORD",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/CredentialItem"
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "bad input parameter"
          }
        }
      }
    },
    "/username/{USERNAME}" : {
      "get" : {
        "tags" : [ "Credential Checker" ],
        "summary" : "searches database for a matching USERNAME",
        "operationId" : "searchUsername",
        "description" : "By passing in the appropriate options (USERNAME in path), you can search for\nthe exact given USERNAME in our database.\n",
        "parameters" : [ {
          "in" : "path",
          "name" : "USERNAME",
          "description" : "pass the USERNAME to be checked in our database",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "search results matching the same USERNAME",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/CredentialItem"
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "bad input parameter"
          }
        }
      }
    },
    "/analysis/": {
      "post": {
        "tags" : [ "Analysis" ],
        "summary": "Analyze IP address using fetch data and Gemma",
        "operationId": "analyzeIP",
        "description": "By passing in the appropriate options (IP,User prompt in Request body), you can get \nthe answer generate by Gemma.\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ipAddress": {
                    "type": "string",
                    "example": "192.168.1.1"
                  },
                  "userPrompt":{
                    "type":"string",
                    "example": "Please analyze the following IP address and provide a brief reputation report"
                  }
                },
                "required": ["ipAddress"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis result",
            "content": {
              "application/json": {
                "example": {
                  "IP Data": {},
                  "Result": "Some analysis result here"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/analysis/feedback": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Submit user feedback on the LLM analysis result",
        "description": "Allows users to give feedback on the IP analysis result generated by the LLM.",
        "operationId": "feedback",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ipAddress": {
                    "type": "string",
                    "example": "8.8.8.8"
                  },
                  "summary": {
                    "type": "string",
                    "example": "This IP is clean and belongs to Google."
                  },
                  "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5,
                    "example": 4
                  },
                  "feedback": {
                    "type": "string",
                    "example": "Simple and clear explanation."
                  }
                },
                "required": ["ipAddress", "summary", "rating"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feedback submitted successfully"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/analysis/getFeedback": {
    "get": {
      "tags": ["Analysis"],
      "summary": "Retrieve feedback for IP analysis results",
      "description": "Fetch user feedbacks optionally filtered by IP address, type (best/worst/latest), and result limit.",
      "parameters": [
        {
          "in": "query",
          "name": "ipAddress",
          "required": false,
          "description": "IP address to filter feedback",
          "schema": {
            "type": "string",
            "example": "8.8.8.8"
          }
        },
        {
          "in": "query",
          "name": "type",
          "required": false,
          "description": "Type of feedback to retrieve (best, worst, latest)",
          "schema": {
            "type": "string",
            "enum": ["best", "worst", "latest"],
            "default": "latest"
          }
        },
        {
          "in": "query",
          "name": "limit",
          "required": false,
          "description": "Number of feedback results to return",
          "schema": {
            "type": "integer",
            "default": 3
          }
        }
      ],
      "responses": {
        "200": {
          "description": "List of feedback entries",
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ipAddress": { "type": "string" },
                    "summary": { "type": "string" },
                    "rating": { "type": "number" },
                    "feedback": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        },
        "500": {
          "description": "Failed to retrieve feedback"
        }
      }
    }
  }


  },
  "components" : {
    "securitySchemes" : {
      "ApiKeyAuth" : {
        "type" : "apiKey",
        "in" : "header",
        "name" : "X-API-Key",
        "description" : "Partner API key for authentication. Required for STIX import endpoint."
      }
    },
    "schemas" : {
      "AddressItem" : {
        "type" : "object",
        "required" : [ "id", "address", "source", "type", "updated", "timestamp" ],
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int",
            "example" : 4
          },
          "data":{
            "type":"string",
            "example":"24.1.124.227"
          },
          "source" : {
            "type" : "string",
            "format" : "url",
            "example" : "https://www.dshield.org/block.txt"
          },
          "type" : {
            "type" : "string",
            "example" : "IP or SUBNET"
          },
          "updated" : {
            "type" : "string",
            "format" : "date-time",
            "example" : "2023-10-12 13:15:25"
          },
          "timestamp" : {
            "type" : "string",
            "format" : "timestamp",
            "example" : "1697119500.098213"
          }
        }
      },
      "CredentialItem" : {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "updated": {
            "type": "string",
            "format": "date"  
          },
          "timestamp": {
            "type": "number",
            "format": "double"  
          },
          "destination_port": {
            "type": "integer"
          },
          "protocol": {
            "type": "string"
          },
          "credentials": {
            "type": "object",
            "properties": {
              "source_ip": {
                "type": "91.92.253.23"
              },
              "usernames": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "passwords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }              
    }
  }
},
"apis": ["./routes/*.js"]
}
